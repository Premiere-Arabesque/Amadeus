# Runtime server
AMADEUS_HOST=127.0.0.1
AMADEUS_PORT=8010

# Core model routing
AMADEUS_DIALOGUE_PROVIDER=anthropic
AMADEUS_DIALOGUE_MODEL=
AMADEUS_DIALOGUE_API_KEY_ENV=ANTHROPIC_API_KEY
AMADEUS_DIALOGUE_BASE_URL=

AMADEUS_DECISION_PROVIDER=openai
AMADEUS_DECISION_MODEL=
AMADEUS_DECISION_API_KEY_ENV=OPENAI_API_KEY
AMADEUS_DECISION_BASE_URL=

AMADEUS_MEMORY_PROVIDER=openai
AMADEUS_MEMORY_MODEL=
AMADEUS_MEMORY_API_KEY_ENV=OPENAI_API_KEY
AMADEUS_MEMORY_BASE_URL=

# Provider API keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# QQ bot
AMADEUS_QQ_ENABLED=false
AMADEUS_QQ_APP_ID=
AMADEUS_QQ_APP_SECRET=
AMADEUS_QQ_ACCESS_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken
AMADEUS_QQ_API_BASE_URL=https://api.sgroup.qq.com
AMADEUS_QQ_SANDBOX_API_BASE_URL=https://sandbox.api.sgroup.qq.com
AMADEUS_QQ_USE_SANDBOX=true
